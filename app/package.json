{
  "name": "app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate-data-manifest && vite --host 127.0.0.1",
    "admin:macro-events": "node scripts/macro-events-admin-api.mjs",
    "build": "npm run generate-data-manifest && vite build",
    "build:pages": "npm run generate-data-manifest && vite build && node scripts/prepare-github-pages.mjs",
    "lint": "node scripts/lint-source.mjs",
    "test": "node --test",
    "check": "npm run lint && npm test && npm run verify-market-calendar && npm run build",
    "preview": "vite preview --host 127.0.0.1",
    "update-data": "node scripts/update-market-data.mjs",
    "update-crypto-liquidity": "node scripts/update-crypto-liquidity-data.mjs",
    "update-market-session": "node scripts/update-market-session-data.mjs",
    "update-market-session-calendar": "node scripts/update-market-session-data.mjs --calendar-only",
    "update-chip-chain": "node scripts/update-chip-chain-data.mjs chip",
    "update-robot-chain": "node scripts/update-chip-chain-data.mjs robot",
    "update-equity-fast-data": "python scripts/update-equity-fast-data.py",
    "update-equity-data": "python scripts/update-equity-data.py",
    "sync-manual-macro-events": "node scripts/sync-manual-macro-events-from-supabase.mjs",
    "update-macro-calendar": "python scripts/update-macro-calendar.py",
    "update-chart-series": "node scripts/update-chart-series-data.mjs",
    "persist-market-history": "node scripts/persist-market-metric-history.mjs",
    "generate-data-manifest": "node scripts/generate-data-manifest.mjs",
    "verify-market-calendar": "node scripts/verify-market-session-calendar.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "vite": "6.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {}
}
