# Copy this file to app/.env.local and fill values locally. Never commit app/.env.local.
CMC_PRO_API_KEY=
SOSOVALUE_API_KEY=
FRED_API_KEY=

# Backend/CI only. Prefer the new opaque secret key; keep the legacy service-role
# JWT empty unless it is still needed during migration.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional SEC automation for BitMine holdings. Use a project name plus a real
# contact email as required by SEC fair-access guidance; keep it local/secret.
SEC_USER_AGENT=

# Optional auxiliary cross-check only.
BLOCKBEATS_API_KEY=
BLOCKBEATS_AUX_ENABLED=0
